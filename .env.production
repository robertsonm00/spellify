# Production build settings (committed — applies to Vercel + local prod builds).
# Supabase keys are NOT here; they live in .env.local / Vercel env vars.

# Do not emit .map source-map files in production. Source maps decode the
# minified bundle back into the original commented source, so shipping them
# hands anyone a fully readable copy of the app's code via DevTools. Off here
# means production ships only the minified bundle. (Stack traces from live
# errors become minified too — accepted trade-off.)
GENERATE_SOURCEMAP=false
